# Copy this file to .env.local and fill in the values from your Convex dashboard.
# `npx convex dev` will populate these automatically the first time you run it.

# The deployment URL the frontend connects to (e.g. https://your-deployment.convex.cloud)
VITE_CONVEX_URL=

# Set automatically by the Convex CLI — do not edit by hand.
CONVEX_DEPLOYMENT=
